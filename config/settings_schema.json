[
  {
    "name": "theme_info",
    "theme_name": "Skeleton",
    "theme_version": "0.1.0",
    "theme_author": "Shopify",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "work_sans_n7",
        "label": "Heading font"
      },
      {
        "type": "range",
        "id": "font_size_base",
        "min": 12,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "Base font size",
        "default": 16
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      },
      {
        "type": "range",
        "id": "spacing_base",
        "min": 4,
        "max": 32,
        "step": 2,
        "unit": "px",
        "label": "Base spacing",
        "default": 16
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#FFFFFF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#333333",
        "label": "t:labels.foreground"
      },
      {
        "type": "color",
        "id": "primary_color",
        "default": "#000000",
        "label": "Primary color"
      },
      {
        "type": "color",
        "id": "primary_text_color",
        "default": "#FFFFFF",
        "label": "Primary text color"
      },
      {
        "type": "color",
        "id": "link_color",
        "default": "#000000",
        "label": "Link color"
      },
      {
        "type": "color",
        "id": "border_color",
        "default": "#E5E5E5",
        "label": "Border color"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      },
      {
        "type": "range",
        "id": "button_corner_radius",
        "min": 0,
        "max": 30,
        "step": 1,
        "unit": "px",
        "label": "Button border radius",
        "default": 4
      },
      {
        "type": "range",
        "id": "card_corner_radius",
        "min": 0,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "Card border radius",
        "default": 0
      }
    ]
  }
]
